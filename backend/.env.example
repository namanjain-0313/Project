# =============================================================
# GOE — Global Ontology Engine
# Environment Variables Template
# =============================================================
# HOW TO USE:
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub — only commit this file
# =============================================================


# ─── NEO4J AURA (Graph Database) ─────────────────────────────
# Get these from: aura.neo4j.io
# Create account → New Instance → AuraDB Free
# Save credentials immediately — password shown only once

NEO4J_URL=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password-here


# ─── ANTHROPIC (Claude API) ───────────────────────────────────
# Get from: console.anthropic.com → API Keys
# Add at least $5 credit before the hackathon

GEMINI_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── APP CONFIG ───────────────────────────────────────────────
# Change ENVIRONMENT to "development" when running locally

ENVIRONMENT=production
LOG_LEVEL=INFO